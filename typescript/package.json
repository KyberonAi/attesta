{
  "name": "@kyberon/attesta",
  "version": "0.1.0",
  "description": "Human-in-the-loop approval framework for AI agent actions",
  "type": "module",
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/esm/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/esm/index.d.ts",
        "default": "./dist/esm/index.js"
      },
      "require": {
        "types": "./dist/cjs/index.d.ts",
        "default": "./dist/cjs/index.js"
      }
    },
    "./challenges": {
      "import": {
        "types": "./dist/esm/challenges/index.d.ts",
        "default": "./dist/esm/challenges/index.js"
      },
      "require": {
        "types": "./dist/cjs/challenges/index.d.ts",
        "default": "./dist/cjs/challenges/index.js"
      }
    },
    "./renderers": {
      "import": {
        "types": "./dist/esm/renderers/index.d.ts",
        "default": "./dist/esm/renderers/index.js"
      },
      "require": {
        "types": "./dist/cjs/renderers/index.d.ts",
        "default": "./dist/cjs/renderers/index.js"
      }
    },
    "./integrations": {
      "import": {
        "types": "./dist/esm/integrations/index.d.ts",
        "default": "./dist/esm/integrations/index.js"
      },
      "require": {
        "types": "./dist/cjs/integrations/index.d.ts",
        "default": "./dist/cjs/integrations/index.js"
      }
    }
  },
  "files": [
    "dist",
    "src",
    "LICENSE"
  ],
  "scripts": {
    "build:esm": "tsc --project tsconfig.json",
    "build:cjs": "tsc --project tsconfig.cjs.json",
    "build": "npm run build:esm && npm run build:cjs",
    "typecheck": "tsc --noEmit",
    "test": "node --test tests/*.test.mjs",
    "clean": "rm -rf dist"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "ai",
    "agent",
    "attesta",
    "human-in-the-loop",
    "approval",
    "safety",
    "risk",
    "audit",
    "trust"
  ],
  "license": "MIT",
  "devDependencies": {
    "typescript": "^5.3.0"
  },
  "peerDependencies": {
    "chalk": "^5.0.0",
    "@langchain/core": ">=0.3.80",
    "ai": ">=5.0.52"
  },
  "peerDependenciesMeta": {
    "chalk": {
      "optional": true
    },
    "@langchain/core": {
      "optional": true
    },
    "ai": {
      "optional": true
    }
  }
}
