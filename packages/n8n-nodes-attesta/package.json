{
  "name": "n8n-nodes-attesta",
  "version": "0.1.0",
  "description": "n8n community node for Attesta human-in-the-loop approval gates",
  "keywords": ["n8n-community-node-package"],
  "license": "MIT",
  "main": "dist/nodes/AttestaGate/AttestaGate.node.js",
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": ["dist/credentials/AttestaApi.credentials.js"],
    "nodes": ["dist/nodes/AttestaGate/AttestaGate.node.js"]
  },
  "scripts": {
    "build": "tsc",
    "test": "jest",
    "clean": "rm -rf dist"
  },
  "jest": {
    "transform": {
      "^.+\\.ts$": ["ts-jest", { "diagnostics": false }]
    },
    "moduleNameMapper": {
      "^@kyberon/attesta$": "<rootDir>/__mocks__/@kyberon/attesta.ts"
    }
  },
  "dependencies": {
    "@kyberon/attesta": "^0.1.0"
  },
  "peerDependencies": {
    "n8n-workflow": ">=1.0.0"
  },
  "devDependencies": {
    "typescript": "^5.3.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.0",
    "@types/jest": "^29.5.0",
    "n8n-workflow": "^2.9.0"
  },
  "files": ["dist"],
  "engines": {
    "node": ">=18"
  }
}
