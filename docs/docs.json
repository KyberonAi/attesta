{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "maple",
  "name": "Attesta",
  "logo": { "dark": "/logo/dark.svg", "light": "/logo/light.svg" },
  "favicon": "/favicon.svg",
  "colors": {
    "primary": "#16A34A",
    "light": "#22C55E",
    "dark": "#15803D"
  },
  "background": {
    "color": {
      "light": "#FFFFFF",
      "dark": "#1A1D1C"
    }
  },
  "fonts": {
    "heading": { "family": "Space Grotesk", "weight": 700 },
    "body": { "family": "Inter", "weight": 400 }
  },
  "navbar": {
    "links": [
      { "label": "GitHub", "href": "https://github.com/KyberonAi/attesta", "type": "github" }
    ],
    "primary": { "label": "Get Started", "href": "/quickstart", "type": "button" }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Getting Started",
            "pages": ["introduction", "quickstart", "installation", "how-it-works"]
          },
          {
            "group": "Core Concepts",
            "pages": [
              "concepts/risk-scoring", "concepts/risk-levels", "concepts/risk-scorers",
              "concepts/challenges", "concepts/challenge-confirm", "concepts/challenge-quiz",
              "concepts/challenge-teach-back", "concepts/challenge-multi-party",
              "concepts/trust-engine", "concepts/audit-trail",
              "concepts/domain-profiles", "concepts/renderers"
            ]
          },
          {
            "group": "Configuration",
            "pages": [
              "configuration/attesta-yaml", "configuration/policy-section",
              "configuration/risk-section", "configuration/trust-section",
              "configuration/domain-activation"
            ]
          },
          {
            "group": "Domain Profiles",
            "pages": [
              "domains/overview", "domains/custom-domains"
            ]
          },
          {
            "group": "Examples",
            "pages": [
              "examples/devops-pipeline", "examples/multi-framework"
            ]
          },
          {
            "group": "Guides",
            "pages": [
              "guides/custom-risk-scorer", "guides/custom-renderer",
              "guides/custom-challenge", "guides/production-deployment",
              "guides/testing", "guides/migration"
            ]
          },
          {
            "group": "TypeScript",
            "pages": ["typescript/getting-started", "typescript/api-differences"]
          },
          {
            "group": "Resources",
            "pages": ["changelog", "faq"]
          }
        ]
      },
      {
        "tab": "Integrations",
        "groups": [
          {
            "group": "Code Integrations",
            "pages": [
              "integrations/overview", "integrations/langchain", "integrations/openai-agents",
              "integrations/anthropic-claude", "integrations/crewai",
              "integrations/mcp", "integrations/vercel-ai"
            ]
          },
          {
            "group": "No-Code Platforms",
            "pages": [
              "no-code/overview", "no-code/n8n", "no-code/flowise",
              "no-code/langflow", "no-code/dify"
            ]
          }
        ]
      },
      {
        "tab": "API Reference",
        "groups": [
          {
            "group": "API Reference",
            "pages": [
              "api/gate-decorator", "api/attesta-class", "api/action-context",
              "api/approval-result", "api/risk-assessment", "api/protocols", "api/enums",
              "api/events", "api/exporters", "api/webhooks", "api/environment"
            ]
          }
        ]
      },
      {
        "tab": "CLI",
        "groups": [
          {
            "group": "CLI Reference",
            "pages": ["cli/overview", "cli/init", "cli/audit", "cli/trust", "cli/mcp-wrap"]
          }
        ]
      }
    ],
    "global": {}
  },
  "announcement": {
    "title": "Attesta is in early release (v0.1.x). APIs may change between minor versions.",
    "url": "/changelog"
  },
  "footer": {
    "socials": {
      "github": "https://github.com/KyberonAi/attesta"
    }
  },
  "branding": false,
  "layout": "sidenav",
  "styling": {
    "codeblocks": {
      "theme": {
        "light": "github-light",
        "dark": "github-dark-dimmed"
      }
    }
  },
  "feedback": { "thumbsRating": true, "suggestEdit": true, "raiseIssue": true },
  "redirects": [
    { "source": "/why-attesta", "destination": "/introduction" }
  ]
}
